SBG_MARKING_DB_URL=postgresql+psycopg://postgres:postgres@localhost:5433/sbg_marking_py
SBG_MARKING_PORT=8090
SBG_MARKING_RESERVATION_TTL_SEC=900
SBG_MARKING_CLEANUP_INTERVAL_SEC=30
# Set to 1 to skip the background cleanup scheduler (tests, migrations, one-shot scripts).
SBG_MARKING_DISABLE_SCHEDULER=0
SBG_MARKING_LOG_LEVEL=INFO
