  "item": [
    {
      "name": "Health / Actuator",
      "item": [
        {
          "name": "GET /actuator/health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"HTTP 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test(\"status is UP\", function () {",
                  "  pm.expect(data.status).to.eql(\"UP\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health"
          }
        }
      ]
    },
    {
      "name": "Import",
      "item": [
        {
          "name": "POST /api/v1/km/import/full (Seed)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set(\"seedBatchId\", \"seed-\" + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"HTTP 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test(\"import response has counters\", function () {",
                  "  pm.expect(data).to.have.property(\"added\");",
                  "  pm.expect(data).to.have.property(\"updated\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batchId\": \"{{seedBatchId}}\",\n  \"items\": [\n    {\n      \"markCode\": \"KM-1001\",\n      \"item\": \"{{productItem}}\",\n      \"gtin\": \"{{productGtin}}\",\n      \"productType\": \"{{productType}}\",\n      \"valid\": true,\n      \"blocked\": false,\n      \"status\": \"AVAILABLE\",\n      \"fifoTsEpochMs\": 1000\n    },\n    {\n      \"markCode\": \"KM-1002\",\n      \"item\": \"{{productItem}}\",\n      \"gtin\": \"{{productGtin}}\",\n      \"productType\": \"{{productType}}\",\n      \"valid\": true,\n      \"blocked\": false,\n      \"status\": \"AVAILABLE\",\n      \"fifoTsEpochMs\": 2000\n    },\n    {\n      \"markCode\": \"KM-9999-BAD\",\n      \"item\": \"{{productItem}}\",\n      \"gtin\": \"{{productGtin}}\",\n      \"productType\": \"{{productType}}\",\n      \"valid\": false,\n      \"blocked\": false,\n      \"status\": \"AVAILABLE\",\n      \"fifoTsEpochMs\": 3000\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/km/import/full"
          }
        },
        {
          "name": "POST /api/v1/km/import/delta",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set(\"deltaBatchId\", \"delta-\" + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"HTTP 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batchId\": \"{{deltaBatchId}}\",\n  \"items\": [\n    {\n      \"markCode\": \"KM-1003\",\n      \"item\": \"{{productItem}}\",\n      \"gtin\": \"{{productGtin}}\",\n      \"productType\": \"{{productType}}\",\n      \"valid\": true,\n      \"blocked\": false,\n      \"status\": \"AVAILABLE\",\n      \"fifoTsEpochMs\": 4000\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/km/import/delta"
          }
        }
      ]
    },
    {
      "name": "Sale Success Flow",
      "item": [
        {
          "name": "POST /api/v1/marking/resolve-and-reserve (Auto FIFO)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set(\"saleResolveOpId\", \"sale-resolve-\" + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"HTTP 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test(\"resolve accepted\", function () {",
                  "  pm.expect([\"ACCEPT_AUTO_SELECTED\", \"ACCEPT_SCANNED\"]).to.include(data.result);",
                  "});",
                  "if (data.reservationId) { pm.collectionVariables.set(\"saleReservationId\", data.reservationId); }",
                  "if (data.appliedMark) { pm.collectionVariables.set(\"saleAppliedMark\", data.appliedMark); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operationId\": \"{{saleResolveOpId}}\",\n  \"shopId\": \"{{shopId}}\",\n  \"posId\": \"{{posId}}\",\n  \"cashierId\": \"{{cashierId}}\",\n  \"product\": {\n    \"barcode\": \"{{productBarcode}}\",\n    \"item\": \"{{productItem}}\",\n    \"productType\": \"{{productType}}\",\n    \"gtin\": \"{{productGtin}}\"\n  },\n  \"scannedMark\": \"NOT-IN-POOL\",\n  \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/marking/resolve-and-reserve"
          }
        },
        {
          "name": "POST /api/v1/marking/sold-confirm",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set(\"soldConfirmOpId\", \"sold-confirm-\" + Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"HTTP 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.test(\"sale confirmed\", function () {",
                  "  pm.expect(data.success).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operationId\": \"{{soldConfirmOpId}}\",\n  \"reservationId\": \"{{saleReservationId}}\",\n  \"markCode\": \"{{saleAppliedMark}}\",\n  \"receiptId\": \"SALE-{{soldConfirmOpId}}\",\n  \"receiptNumber\": 1001,\n  \"shiftNumber\": 1,\n  \"fiscalDocId\": 1001001,\n  \"fiscalSign\": 9001001\n}"
            },
            "url": "{{baseUrl}}/api/v1/marking/sold-confirm"
          }
        }
      ]
    },
