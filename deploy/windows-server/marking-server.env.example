# Copy to marking-server.env and edit values.

# Optional: override JAVA_HOME used by start-server.ps1
# JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-17.0.14.7-hotspot

# Optional JVM memory and extra args
HEAP_OPTS=-Xms256m -Xmx1024m
JAVA_OPTS=

# Server bind port
SERVER_PORT=8080

# Database
SBG_MARKING_DB_URL=jdbc:postgresql://127.0.0.1:5432/sbg_marking
SBG_MARKING_DB_USER=postgres
SBG_MARKING_DB_PASSWORD=change-me

# Keep false when security is handled by external system
SBG_MARKING_AUTH_ENABLED=false
SBG_MARKING_AUTH_ADMIN_TOKEN=
SBG_MARKING_AUTH_OPERATOR_TOKEN=
